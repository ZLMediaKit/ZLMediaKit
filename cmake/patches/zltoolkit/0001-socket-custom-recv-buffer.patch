--- a/src/Network/Socket.cpp
+++ b/src/Network/Socket.cpp
@@ -279,0 +280,6 @@ bool Socket::attachEvent(const SockNum::Ptr &sock) {
+    if (_read_buffer) {
+        assert(sock->type() == SockNum::Sock_UDP);
